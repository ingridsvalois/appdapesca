# Variáveis de ambiente - raiz

# URL pública do frontend (ex.: http://localhost:3000)
FRONTEND_URL=http://localhost:3000

# URL pública do backend (ex.: http://localhost:5000)
BACKEND_URL=http://localhost:5000

# Configuração do Postgres (para docker-compose)
POSTGRES_USER=appdapesca
POSTGRES_PASSWORD=appdapesca_password
POSTGRES_DB=appdapesca_db

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_seu_webhook_secret_aqui

# Admin (opcional - e-mail para notificação de novos pedidos pagos)
ADMIN_EMAIL=admin@seudominio.com

# JWT (para backend / docker-compose)
JWT_ACCESS_SECRET=defina_um_segredo_forte
JWT_REFRESH_SECRET=defina_outro_segredo_forte

# Cloudinary ou S3 (ajustar conforme provedor escolhido)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Railway: adicione NODE_OPTIONS=--dns-result-order=ipv4first nas variáveis
# (ajuda no envio de e-mail, pois Railway não suporta IPv6)

# SMTP - Envio de e-mails (recuperação de senha, etc.)
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_USER=seu-email@exemplo.com
SMTP_PASS=sua-senha-ou-app-password
SMTP_FROM="Loja App da Pesca <noreply@seudominio.com>"
# Alternativa: EMAIL_FROM (usado se SMTP_FROM não estiver definido)

